# --- Secrets (NEVER COMMIT) ---
*.env
*.envrc
secrets/
**/api_key*
**/*token*
**/*secret*
**/credentials*

# --- Swift / SPM ---
.build/
.swiftpm/
Package.resolved
*.xcodeproj/
*.xcworkspace/
DerivedData/

# --- macOS ---
.DS_Store
._*

# --- Build outputs ---
*.dmg
dist/StatusOrbit.app/
dist/*.dmg
dist/*.sha256

# ============================================================
# 비텍스트 파일 — Hugging Face 동기화 관리 (j00n98/Claude-Code-Storage)
